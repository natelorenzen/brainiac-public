# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Modal workers
# 1. pip install modal && modal token new
# 2. One-time weight download: modal run modal/inference.py::download_berg_weights
# 3. modal deploy modal/inference.py
# 4. Copy endpoint URLs from Modal dashboard

# BERG CPU worker — YouTube static thumbnails (BrainiacThumbnailInference)
MODAL_THUMBNAIL_URL=https://your-org--brainiac-thumbnail-inference.modal.run

# TRIBE v2 GPU worker — uploaded videos (BrainiacInference)
MODAL_INFERENCE_URL=https://your-org--brainiac-inference.modal.run

# Encryption key for OAuth tokens at rest
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Meta Ads OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://yourdomain.com/api/oauth/meta/callback

# YouTube Data API (optional — view count enrichment only)
YOUTUBE_DATA_API_KEY=

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Budget caps (defaults shown)
MONTHLY_BUDGET_CAP_USD=300.0
COST_PER_ANALYSIS_USD=0.01

# Legal version — bump when ToS/PP changes to trigger re-consent
CURRENT_LEGAL_VERSION=1.0.0
